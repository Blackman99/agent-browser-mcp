{
  "name": "agent-browser-mcp",
  "version": "0.1.0",
  "description": "MCP server wrapper for the local agent-browser CLI with Codex bootstrap support.",
  "type": "module",
  "bin": {
    "agent-browser-mcp": "dist/src/cli/index.js"
  },
  "files": [
    "dist",
    "codex",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/cli/index.ts serve",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.11.0",
    "execa": "^9.5.2",
    "zod": "^3.24.3"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3",
    "vitest": "^3.1.1"
  }
}
